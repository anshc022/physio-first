---
interface Props {
	title?: string;
}

const { title = 'PhysioFirst | Physiotherapist in Lucknow' } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content="Professional physiotherapy care delivered to your doorstep in Lucknow. Home visits, post-surgery rehab, sports injury recovery by Dr. Muskan, BPT." />
	<meta name="keywords" content="physiotherapist lucknow, home physiotherapy, BPT, sports injury, orthopedic rehab, neurological rehab" />

	<!-- Fonts -->
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

	<title>{title}</title>
</head>
<body class="bg-white text-gray-900 font-sans antialiased overflow-x-hidden">
	<slot />

	<style is:global>
		body {
			font-family: 'Inter', system-ui, -apple-system, sans-serif;
		}

		/* Scroll animations */
		[data-animate] {
			opacity: 0;
			transform: translateY(24px);
			transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
						transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
		}
		[data-animate].visible {
			opacity: 1;
			transform: translateY(0);
		}

		/* Smooth scroll behavior */
		html {
			scroll-behavior: smooth;
		}

		/* Selection color */
		::selection {
			background: rgba(13, 148, 136, 0.15);
		}

		/* Custom scrollbar */
		::-webkit-scrollbar {
			width: 6px;
		}
		::-webkit-scrollbar-track {
			background: transparent;
		}
		::-webkit-scrollbar-thumb {
			background: rgba(0,0,0,0.15);
			border-radius: 3px;
		}
		::-webkit-scrollbar-thumb:hover {
			background: rgba(0,0,0,0.3);
		}
	</style>

	<script>
		// Intersection Observer for scroll animations
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const el = entry.target as HTMLElement;
					const delay = parseInt(el.dataset.delay || '0');
					setTimeout(() => el.classList.add('visible'), delay);
					observer.unobserve(el);
				}
			});
		}, {
			threshold: 0.1,
			rootMargin: '0px 0px -50px 0px'
		});

		document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
	</script>
</body>
</html>
