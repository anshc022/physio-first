---
const serviceOptions = [
	'Home Visit Physiotherapy',
	'Post-Surgery Rehabilitation',
	'Back & Neck Pain Management',
	'Sports Injury Recovery',
	'Geriatric Mobility Care',
	'Neurological Rehabilitation',
	'Other',
];
---

<section id="booking" class="py-28 bg-gray-900 relative overflow-hidden">
	<!-- Subtle grid -->
	<div class="absolute inset-0 opacity-[0.04]"
		style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
	</div>

	<div class="max-w-6xl mx-auto px-6 relative z-10">
		<div class="grid lg:grid-cols-2 gap-16 items-start">
			<!-- Left: Info -->
			<div data-animate="fade-up">
				<p class="text-sm tracking-[0.2em] uppercase text-teal-400 font-medium mb-6">Book a Session</p>
				<h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight mb-8">
					Start your<br/>recovery today.
				</h2>
				<p class="text-gray-400 leading-relaxed mb-12 max-w-md">
					Fill out the form and I'll confirm your appointment within 24 hours.
					Or reach out directly via WhatsApp for instant booking.
				</p>

				<!-- Process -->
				<div class="space-y-6">
					{[
						{ step: '01', text: 'Submit your request', sub: 'Takes 2 minutes' },
						{ step: '02', text: 'Confirmation call', sub: 'Within 24 hours' },
						{ step: '03', text: 'Assessment session', sub: 'In-person or at home' },
						{ step: '04', text: 'Treatment begins', sub: 'Personalized plan' },
					].map(item => (
						<div class="flex gap-4 items-start">
							<span class="text-xs text-teal-400 font-mono mt-1 w-6">{item.step}</span>
							<div>
								<p class="text-white text-sm font-medium">{item.text}</p>
								<p class="text-gray-500 text-xs mt-0.5">{item.sub}</p>
							</div>
						</div>
					))}
				</div>

				<!-- WhatsApp -->
				<a href="https://wa.me/91XXXXXXXXXX?text=Hi%2C%20I%20would%20like%20to%20book%20a%20physiotherapy%20session."
					target="_blank" rel="noopener"
					class="mt-12 inline-flex items-center gap-3 border border-gray-700 text-white px-6 py-4 rounded-xl hover:border-green-500 hover:bg-green-500/5 transition-all duration-300">
					<svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					<span class="text-sm font-medium">Or book via WhatsApp</span>
				</a>
			</div>

			<!-- Right: Form -->
			<div data-animate="fade-up" data-delay="200">
				<form class="bg-white rounded-2xl p-8 md:p-10" id="booking-form">
					<div class="space-y-5">
						<div class="grid sm:grid-cols-2 gap-5">
							<div>
								<label class="block text-xs text-gray-400 mb-2">Name</label>
								<input type="text" name="name" required
									class="w-full bg-gray-50 border-0 rounded-lg px-4 py-3 text-sm text-gray-900 placeholder-gray-300 focus:ring-2 focus:ring-teal-500/20 transition-all"
									placeholder="Your name" />
							</div>
							<div>
								<label class="block text-xs text-gray-400 mb-2">Phone</label>
								<input type="tel" name="phone" required
									class="w-full bg-gray-50 border-0 rounded-lg px-4 py-3 text-sm text-gray-900 placeholder-gray-300 focus:ring-2 focus:ring-teal-500/20 transition-all"
									placeholder="+91" />
							</div>
						</div>

						<div>
							<label class="block text-xs text-gray-400 mb-2">Email</label>
							<input type="email" name="email"
								class="w-full bg-gray-50 border-0 rounded-lg px-4 py-3 text-sm text-gray-900 placeholder-gray-300 focus:ring-2 focus:ring-teal-500/20 transition-all"
								placeholder="your@email.com" />
						</div>

						<div class="grid sm:grid-cols-2 gap-5">
							<div>
								<label class="block text-xs text-gray-400 mb-2">Service</label>
								<select name="service" required
									class="w-full bg-gray-50 border-0 rounded-lg px-4 py-3 text-sm text-gray-500 focus:ring-2 focus:ring-teal-500/20 transition-all">
									<option value="">Select</option>
									{serviceOptions.map(s => (
										<option value={s}>{s}</option>
									))}
								</select>
							</div>
							<div>
								<label class="block text-xs text-gray-400 mb-2">Preferred Date</label>
								<input type="date" name="date" required
									class="w-full bg-gray-50 border-0 rounded-lg px-4 py-3 text-sm text-gray-500 focus:ring-2 focus:ring-teal-500/20 transition-all" />
							</div>
						</div>

						<div>
							<label class="block text-xs text-gray-400 mb-2">Home Address</label>
							<input type="text" name="address"
								class="w-full bg-gray-50 border-0 rounded-lg px-4 py-3 text-sm text-gray-900 placeholder-gray-300 focus:ring-2 focus:ring-teal-500/20 transition-all"
								placeholder="For home visit appointments" />
						</div>

						<div>
							<label class="block text-xs text-gray-400 mb-2">Condition</label>
							<textarea name="condition" rows="3"
								class="w-full bg-gray-50 border-0 rounded-lg px-4 py-3 text-sm text-gray-900 placeholder-gray-300 focus:ring-2 focus:ring-teal-500/20 transition-all resize-none"
								placeholder="Brief description of your pain or condition"></textarea>
						</div>

						<button type="submit"
							class="w-full bg-gray-900 text-white rounded-lg py-3.5 text-sm font-medium hover:bg-gray-800 transition-all duration-300">
							Request Appointment
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</section>
