---
const serviceOptions = [
	'Home Visit Physiotherapy',
	'Post-Surgery Rehabilitation',
	'Back & Neck Pain Management',
	'Sports Injury Recovery',
	'Geriatric Mobility Care',
	'Neurological Rehabilitation',
	'Other',
];
---

<section id="booking" class="py-24 bg-gradient-to-br from-teal-600 via-teal-700 to-teal-800 relative overflow-hidden">
	<!-- Background pattern -->
	<div class="absolute inset-0 opacity-10"
		style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;">
	</div>

	<div class="max-w-5xl mx-auto px-6 relative z-10">
		<div class="text-center mb-12">
			<p class="text-sm uppercase tracking-widest text-teal-200 font-semibold mb-3">Get Started</p>
			<h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Book an Appointment</h2>
			<p class="text-teal-100 max-w-2xl mx-auto">
				Fill out the form below and I'll get back to you within 24 hours to confirm your appointment.
			</p>
		</div>

		<div class="grid lg:grid-cols-5 gap-8">
			<!-- Form -->
			<div class="lg:col-span-3">
				<form class="bg-white rounded-3xl p-8 shadow-2xl" id="booking-form">
					<div class="grid sm:grid-cols-2 gap-5 mb-5">
						<div>
							<label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Full Name</label>
							<input type="text" name="name" required
								class="w-full bg-stone-50 border border-gray-200 rounded-xl px-4 py-3.5 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-400 transition-all"
								placeholder="Your name" />
						</div>
						<div>
							<label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Phone</label>
							<input type="tel" name="phone" required
								class="w-full bg-stone-50 border border-gray-200 rounded-xl px-4 py-3.5 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-400 transition-all"
								placeholder="+91 XXXXX XXXXX" />
						</div>
					</div>

					<div class="mb-5">
						<label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Email</label>
						<input type="email" name="email"
							class="w-full bg-stone-50 border border-gray-200 rounded-xl px-4 py-3.5 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-400 transition-all"
							placeholder="your@email.com" />
					</div>

					<div class="grid sm:grid-cols-2 gap-5 mb-5">
						<div>
							<label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Service</label>
							<select name="service" required
								class="w-full bg-stone-50 border border-gray-200 rounded-xl px-4 py-3.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-400 transition-all">
								<option value="">Select a service</option>
								{serviceOptions.map(s => (
									<option value={s}>{s}</option>
								))}
							</select>
						</div>
						<div>
							<label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Preferred Date</label>
							<input type="date" name="date" required
								class="w-full bg-stone-50 border border-gray-200 rounded-xl px-4 py-3.5 text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-400 transition-all" />
						</div>
					</div>

					<div class="mb-5">
						<label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Home Address (for home visits)</label>
						<input type="text" name="address"
							class="w-full bg-stone-50 border border-gray-200 rounded-xl px-4 py-3.5 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-400 transition-all"
							placeholder="Your complete address" />
					</div>

					<div class="mb-6">
						<label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Describe Your Condition</label>
						<textarea name="condition" rows="3"
							class="w-full bg-stone-50 border border-gray-200 rounded-xl px-4 py-3.5 text-sm text-gray-800 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:border-teal-400 transition-all resize-none"
							placeholder="Brief description of your pain or condition..."></textarea>
					</div>

					<button type="submit"
						class="w-full bg-teal-600 text-white rounded-xl py-4 font-semibold hover:bg-teal-700 hover:shadow-lg transition-all duration-300 text-sm uppercase tracking-wider">
						Request Appointment
					</button>
				</form>
			</div>

			<!-- Sidebar -->
			<div class="lg:col-span-2 flex flex-col gap-6">
				<!-- WhatsApp quick book -->
				<a href="https://wa.me/91XXXXXXXXXX?text=Hi%2C%20I%20would%20like%20to%20book%20a%20physiotherapy%20appointment."
					target="_blank" rel="noopener"
					class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 hover:bg-white/15 transition-all duration-300 group">
					<div class="flex items-center gap-4 mb-3">
						<div class="w-12 h-12 bg-green-500 rounded-xl flex items-center justify-center">
							<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
						</div>
						<div>
							<p class="font-heading font-bold text-white text-base">Quick Book via WhatsApp</p>
							<p class="text-teal-100 text-xs">Get an instant response</p>
						</div>
					</div>
					<p class="text-teal-200 text-sm">Tap to send a pre-filled message and book your session instantly.</p>
				</a>

				<!-- Info cards -->
				<div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6">
					<h4 class="font-heading font-bold text-white mb-4">What to expect</h4>
					<div class="space-y-4">
						{[
							{ step: '01', text: 'Submit your booking request' },
							{ step: '02', text: 'Confirmation call within 24 hours' },
							{ step: '03', text: 'First assessment session' },
							{ step: '04', text: 'Personalized treatment plan' },
						].map(item => (
							<div class="flex gap-3 items-start">
								<span class="text-teal-300 font-mono text-xs font-bold mt-0.5">{item.step}</span>
								<p class="text-teal-100 text-sm">{item.text}</p>
							</div>
						))}
					</div>
				</div>

				<div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6">
					<h4 class="font-heading font-bold text-white mb-2">Home Visits</h4>
					<p class="text-teal-200 text-sm">
						Available across Lucknow. Equipment provided. Flexible morning and evening slots.
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
