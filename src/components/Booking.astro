---
const options = [
	'Home Visit Physiotherapy',
	'Post-Surgery Rehabilitation',
	'Back & Neck Pain',
	'Sports Injury Recovery',
	'Geriatric Mobility Care',
	'Neurological Rehabilitation',
	'Other',
];
---

<section id="booking" class="py-28 bg-neutral-900">
	<div class="max-w-5xl mx-auto px-6">
		<div class="grid lg:grid-cols-5 gap-16">
			<!-- Left -->
			<div class="lg:col-span-2" data-animate-left>
				<p class="text-[11px] tracking-[0.25em] uppercase text-olive-400 font-medium mb-6">Book</p>
				<h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight leading-tight mb-6">
					Start your recovery.
				</h2>
				<p class="text-neutral-400 leading-relaxed text-[15px] mb-10">
					Fill the form and I'll confirm your appointment within 24 hours. Home visits available across Lucknow.
				</p>

				<div class="space-y-5 mb-10">
					<div class="flex gap-3">
						<span class="text-[11px] text-olive-400 font-mono w-5 mt-0.5">01</span>
						<div>
							<p class="text-sm text-white">Submit your request</p>
							<p class="text-xs text-neutral-500">Takes 2 minutes</p>
						</div>
					</div>
					<div class="flex gap-3">
						<span class="text-[11px] text-olive-400 font-mono w-5 mt-0.5">02</span>
						<div>
							<p class="text-sm text-white">Confirmation call</p>
							<p class="text-xs text-neutral-500">Within 24 hours</p>
						</div>
					</div>
					<div class="flex gap-3">
						<span class="text-[11px] text-olive-400 font-mono w-5 mt-0.5">03</span>
						<div>
							<p class="text-sm text-white">Assessment & treatment</p>
							<p class="text-xs text-neutral-500">At your home or clinic</p>
						</div>
					</div>
				</div>

				<div class="border-t border-neutral-800 pt-6 space-y-3 text-sm">
					<div class="flex justify-between">
						<span class="text-neutral-500">Hours</span>
						<span class="text-neutral-300">Mon–Sat, 8 AM – 8 PM</span>
					</div>
					<div class="flex justify-between">
						<span class="text-neutral-500">Phone</span>
						<a href="tel:+919142405611" class="text-neutral-300 hover:text-white transition-colors">+91 91424 05611</a>
					</div>
				</div>

				<a href="https://wa.me/919142405611?text=Hi%2C%20I%27d%20like%20to%20book%20a%20physio%20session."
					target="_blank" rel="noopener"
					class="inline-flex items-center gap-2 mt-8 text-sm text-green-400 hover:text-green-300 transition-colors">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					Or book via WhatsApp
				</a>
			</div>

			<!-- Right: Form -->
			<div class="lg:col-span-3" data-animate-right data-delay="150">
				<form class="bg-white rounded-xl p-7 md:p-9" id="booking-form">
					<div class="space-y-4">
						<div class="grid sm:grid-cols-2 gap-4">
							<div>
								<label class="block text-[11px] text-neutral-400 mb-1.5 tracking-wider uppercase">Name</label>
								<input type="text" name="name" required
									class="w-full border border-neutral-200 rounded-md px-3.5 py-2.5 text-sm focus:outline-none focus:border-neutral-400 transition-colors"
									placeholder="Your name" />
							</div>
							<div>
								<label class="block text-[11px] text-neutral-400 mb-1.5 tracking-wider uppercase">Phone</label>
								<input type="tel" name="phone" required
									class="w-full border border-neutral-200 rounded-md px-3.5 py-2.5 text-sm focus:outline-none focus:border-neutral-400 transition-colors"
									placeholder="+91" />
							</div>
						</div>

						<div>
							<label class="block text-[11px] text-neutral-400 mb-1.5 tracking-wider uppercase">Email (optional)</label>
							<input type="email" name="email"
								class="w-full border border-neutral-200 rounded-md px-3.5 py-2.5 text-sm focus:outline-none focus:border-neutral-400 transition-colors"
								placeholder="your@email.com" />
						</div>

						<div class="grid sm:grid-cols-2 gap-4">
							<div>
								<label class="block text-[11px] text-neutral-400 mb-1.5 tracking-wider uppercase">Service</label>
								<select name="service" required
									class="w-full border border-neutral-200 rounded-md px-3.5 py-2.5 text-sm text-neutral-500 focus:outline-none focus:border-neutral-400 transition-colors">
									<option value="">Select</option>
									{options.map(o => <option value={o}>{o}</option>)}
								</select>
							</div>
							<div>
								<label class="block text-[11px] text-neutral-400 mb-1.5 tracking-wider uppercase">Preferred Date</label>
								<input type="date" name="date" required
									class="w-full border border-neutral-200 rounded-md px-3.5 py-2.5 text-sm text-neutral-500 focus:outline-none focus:border-neutral-400 transition-colors" />
							</div>
						</div>

						<div>
							<label class="block text-[11px] text-neutral-400 mb-1.5 tracking-wider uppercase">Address (for home visits)</label>
							<input type="text" name="address"
								class="w-full border border-neutral-200 rounded-md px-3.5 py-2.5 text-sm focus:outline-none focus:border-neutral-400 transition-colors"
								placeholder="Complete address" />
						</div>

						<div>
							<label class="block text-[11px] text-neutral-400 mb-1.5 tracking-wider uppercase">Your Condition</label>
							<textarea name="condition" rows="3"
								class="w-full border border-neutral-200 rounded-md px-3.5 py-2.5 text-sm focus:outline-none focus:border-neutral-400 transition-colors resize-none"
								placeholder="Briefly describe your pain or condition"></textarea>
						</div>

						<button type="submit"
							class="w-full bg-neutral-900 text-white rounded-md py-3 text-sm font-medium hover:bg-neutral-800 transition-colors">
							Request Appointment
						</button>
					</div>
				</form>

				<div id="booking-ok" class="hidden bg-white rounded-xl p-12 text-center">
					<p class="font-display font-bold text-xl text-neutral-900 mb-2">Request sent.</p>
					<p class="text-sm text-neutral-400 mb-6">I'll confirm your appointment within 24 hours.</p>
					<button id="booking-reset" class="text-sm text-olive-600 hover:text-olive-700">Book another →</button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById('booking-form') as HTMLFormElement;
	const ok = document.getElementById('booking-ok')!;
	const reset = document.getElementById('booking-reset')!;

	form.addEventListener('submit', e => { e.preventDefault(); form.classList.add('hidden'); ok.classList.remove('hidden'); });
	reset.addEventListener('click', () => { form.reset(); ok.classList.add('hidden'); form.classList.remove('hidden'); });
</script>
