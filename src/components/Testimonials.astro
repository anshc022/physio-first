---
const testimonials = [
	{
		name: 'Rajesh K.',
		condition: 'Post knee replacement',
		text: 'The home visit service was a blessing. Professional, punctual, and my recovery has been much faster than expected.',
		rating: 5,
	},
	{
		name: 'Sunita M.',
		condition: 'Chronic back pain',
		text: 'After months of pain, I finally found relief. The treatment plan was thorough and the exercises really helped.',
		rating: 5,
	},
	{
		name: 'Amit S.',
		condition: 'Sports injury - ankle',
		text: 'Got back on the field in 6 weeks. The rehab program was tough but effective. Highly recommend for athletes.',
		rating: 5,
	},
	{
		name: 'Geeta D.',
		condition: 'Geriatric care for father',
		text: 'My father regained his confidence in walking again. The patience and care shown during every session was remarkable.',
		rating: 5,
	},
];
---

<section id="testimonials" class="py-24 bg-white">
	<div class="max-w-7xl mx-auto px-6">
		<div class="text-center mb-16">
			<p class="text-sm uppercase tracking-widest text-teal-600 font-semibold mb-3">Patient Stories</p>
			<h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">Testimonials</h2>
			<p class="text-gray-500 max-w-2xl mx-auto">
				Real experiences from patients who trusted me with their recovery.
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-6">
			{testimonials.map(t => (
				<div class="bg-stone-50 rounded-2xl p-8 border border-gray-100 hover:border-teal-100 hover:shadow-lg transition-all duration-300">
					<!-- Stars -->
					<div class="flex gap-1 mb-4">
						{Array.from({ length: t.rating }).map(() => (
							<svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
								<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
							</svg>
						))}
					</div>

					<p class="text-gray-600 leading-relaxed mb-6 text-[15px]">"{t.text}"</p>

					<div class="flex items-center gap-3">
						<div class="w-10 h-10 bg-teal-100 rounded-full flex items-center justify-center">
							<span class="font-heading font-bold text-teal-600 text-sm">{t.name[0]}</span>
						</div>
						<div>
							<p class="font-heading font-bold text-sm text-gray-900">{t.name}</p>
							<p class="text-xs text-gray-400">{t.condition}</p>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
