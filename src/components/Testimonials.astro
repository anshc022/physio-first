---
const reviews = [
	{
		text: 'The home visit service was a blessing. Professional, punctual, and my recovery has been much faster than I expected after knee replacement.',
		name: 'Rajesh K.',
		context: 'Post knee replacement',
	},
	{
		text: 'After months of constant back pain, I finally found lasting relief. The treatment plan was thorough and the exercises genuinely helped.',
		name: 'Sunita M.',
		context: 'Chronic back pain',
	},
	{
		text: 'Got back on the field in six weeks. The rehab program was demanding but incredibly effective. Highly recommend for athletes.',
		name: 'Amit S.',
		context: 'Ankle sports injury',
	},
	{
		text: 'My father regained his confidence walking independently again. The patience and attentiveness during every session was remarkable.',
		name: 'Geeta D.',
		context: 'Geriatric care — father',
	},
];
---

<section id="testimonials" class="py-28">
	<div class="max-w-5xl mx-auto px-6">
		<div class="grid md:grid-cols-12 gap-12 md:gap-16 mb-16">
			<div class="md:col-span-3" data-animate>
				<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium sticky top-24">Reviews</p>
			</div>
			<div class="md:col-span-9" data-animate data-delay="100">
				<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight leading-tight">
					What patients say.
				</h2>
			</div>
		</div>

		<div class="grid md:grid-cols-2 gap-px bg-neutral-100 rounded-xl overflow-hidden">
			{reviews.map((r, i) => (
				<div class="bg-stone-50 p-8 md:p-10" data-animate data-delay={String(i * 80)}>
					<p class="text-neutral-600 leading-[1.75] mb-8 text-[15px]">"{r.text}"</p>
					<div>
						<p class="text-sm font-medium text-neutral-900">{r.name}</p>
						<p class="text-xs text-neutral-400 mt-0.5">{r.context}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
