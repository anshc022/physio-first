---
const reviews = [
	{
		text: 'The home visit service was a blessing. Professional, punctual, and my recovery has been much faster than I expected after knee replacement.',
		name: 'Rajesh K.',
		context: 'Post knee replacement',
		rating: 5,
	},
	{
		text: 'After months of constant back pain, I finally found lasting relief. The treatment plan was thorough and the exercises genuinely helped.',
		name: 'Sunita M.',
		context: 'Chronic back pain',
		rating: 5,
	},
	{
		text: 'Got back on the field in six weeks. The rehab program was demanding but incredibly effective. Highly recommend for athletes.',
		name: 'Amit S.',
		context: 'Ankle sports injury',
		rating: 5,
	},
	{
		text: 'My father regained his confidence walking independently again. The patience and attentiveness during every session was remarkable.',
		name: 'Geeta D.',
		context: 'Geriatric care — father',
		rating: 5,
	},
];
---

<section id="testimonials" class="py-24 lg:py-32 bg-stone-50">
	<div class="max-w-5xl mx-auto px-6">
		<div class="text-center mb-16" data-animate>
			<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium mb-4">Reviews</p>
			<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight">
				What patients say.
			</h2>
		</div>

		<div class="grid md:grid-cols-2 gap-4">
			{reviews.map((r, i) => (
				<div class="bg-white rounded-2xl p-7 md:p-9 border border-neutral-100 card-lift cursor-grow" data-animate data-delay={String(i * 100)}>
					<!-- Stars -->
					<div class="flex gap-0.5 mb-5">
						{[...Array(r.rating)].map(() => (
							<svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
						))}
					</div>

					<p class="text-neutral-600 leading-[1.8] mb-7 text-[15px]">"{r.text}"</p>

					<div class="flex items-center gap-3 border-t border-neutral-100 pt-5">
						<!-- Avatar circle with initials -->
						<div class="w-9 h-9 bg-olive-100 rounded-full flex items-center justify-center">
							<span class="text-xs font-semibold text-olive-700">{r.name.split(' ').map(w => w[0]).join('')}</span>
						</div>
						<div>
							<p class="text-sm font-medium text-neutral-900">{r.name}</p>
							<p class="text-xs text-neutral-400">{r.context}</p>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
