---
---

<footer class="bg-gray-900 py-12">
	<div class="max-w-7xl mx-auto px-6">
		<div class="grid md:grid-cols-3 gap-8 items-center">
			<!-- Logo -->
			<div>
				<div class="flex items-center gap-2 mb-3">
					<div class="w-8 h-8 bg-teal-600 rounded-lg flex items-center justify-center">
						<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
						</svg>
					</div>
					<span class="font-heading font-bold text-white">PhysioFirst</span>
				</div>
				<p class="text-gray-500 text-sm">Professional physiotherapy care at your doorstep.</p>
			</div>

			<!-- Quick links -->
			<div class="flex flex-wrap gap-6 md:justify-center">
				{['Home', 'About', 'Services', 'Book Now', 'Contact'].map(link => (
					<a href={`#${link.toLowerCase().replace(' ', '')}`}
						class="text-sm text-gray-400 hover:text-teal-400 transition-colors">
						{link}
					</a>
				))}
			</div>

			<!-- Copyright -->
			<div class="md:text-right">
				<p class="text-gray-500 text-sm">&copy; {new Date().getFullYear()} PhysioFirst</p>
				<p class="text-gray-600 text-xs mt-1">Lucknow, UP</p>
			</div>
		</div>
	</div>
</footer>
