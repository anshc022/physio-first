---
const cards = [
	{
		title: 'Home Visit Therapy',
		desc: 'Professional equipment and personalized care, delivered to your home. No travel, no waiting rooms.',
		img: '/images/home-visit.png',
	},
	{
		title: 'Post-Surgery Recovery',
		desc: 'Structured programs for joint replacement, ACL repair, hip surgery, and spinal rehabilitation.',
		img: '/images/ortho-rehab.png',
	},
	{
		title: 'Neurological Care',
		desc: 'Specialized stroke recovery, nerve injury treatment, and movement re-education.',
		img: '/images/neuro-rehab.png',
	},
	{
		title: 'Geriatric Mobility',
		desc: 'Gentle exercise, balance training, and fall prevention for seniors to maintain independence.',
		img: '/images/geriatric-care.png',
	},
];
---

<section class="py-28 bg-white overflow-hidden">
	<div class="max-w-6xl mx-auto px-6 mb-16" data-animate="fade-up">
		<p class="text-sm tracking-[0.2em] uppercase text-teal-600 font-medium mb-4">Focus Areas</p>
		<h2 class="text-4xl md:text-5xl font-medium text-gray-900 tracking-tight">
			Treatment in depth.
		</h2>
	</div>

	<div class="max-w-6xl mx-auto px-6">
		<div class="space-y-6" id="stacked-cards">
			{cards.map((card, i) => (
				<div class="sticky rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100 hover:shadow-lg transition-shadow duration-500"
					style={`top: ${100 + i * 60}px;`}
					data-animate="fade-up" data-delay={String(i * 100)}>
					<div class="grid md:grid-cols-2 gap-0">
						<div class="p-10 md:p-14 flex flex-col justify-center order-2 md:order-1">
							<span class="text-xs text-gray-300 font-mono mb-4">0{i + 1}</span>
							<h3 class="text-2xl md:text-3xl font-medium text-gray-900 tracking-tight mb-4">{card.title}</h3>
							<p class="text-gray-400 leading-relaxed mb-8">{card.desc}</p>
							<a href="#booking"
								class="group inline-flex items-center gap-3 text-sm font-medium text-gray-900 hover:text-teal-600 transition-colors">
								Book this service
								<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
							</a>
						</div>
						<div class="aspect-[4/3] md:aspect-auto overflow-hidden order-1 md:order-2">
							<img src={card.img} alt={card.title}
								class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
								loading="lazy" />
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
