---
const cards = [
	{
		num: '01',
		title: 'Assessment',
		desc: 'Comprehensive evaluation of your condition, mobility, and pain points to build an accurate clinical picture.',
		color: 'bg-olive-50',
		accent: 'text-olive-600',
	},
	{
		num: '02',
		title: 'Treatment Plan',
		desc: 'Personalized, evidence-based protocol combining manual therapy, electrotherapy, and therapeutic exercises.',
		color: 'bg-stone-100',
		accent: 'text-neutral-700',
	},
	{
		num: '03',
		title: 'Home Sessions',
		desc: 'Regular treatment sessions at your home with full equipment. No travel stress, no clinic queues.',
		color: 'bg-neutral-900',
		accent: 'text-olive-400',
		dark: true,
	},
	{
		num: '04',
		title: 'Recovery',
		desc: 'Progressive milestones, exercises you can do between sessions, and ongoing support until you are fully recovered.',
		color: 'bg-olive-600',
		accent: 'text-olive-100',
		dark: true,
	},
];
---

<section class="py-24 lg:py-32 bg-white" id="process">
	<div class="max-w-5xl mx-auto px-6">
		<div class="text-center mb-16" data-animate>
			<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium mb-4">Process</p>
			<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight">
				How it works.
			</h2>
		</div>

		<!-- Stacked cards: each card gets sticky and stacks with offset -->
		<div class="stacked-section">
			{cards.map((c, i) => (
				<div class="stacked-spacer" style={`height: ${i === 0 ? '0' : '45vh'}`}>
					<div
						class:list={['stacked-card sticky rounded-2xl p-8 md:p-12 shadow-lg', c.color]}
						style={`top: ${80 + i * 50}px; z-index: ${10 + i};`}
						data-animate data-delay={String(i * 80)}
					>
						<div class="flex items-start justify-between mb-6">
							<span class:list={['font-mono text-sm font-semibold', c.accent]}>{c.num}</span>
							<div class="w-10 h-10 rounded-full border border-current opacity-30 flex items-center justify-center">
								<span class:list={['text-base', c.dark ? 'text-white' : 'text-neutral-500']}>→</span>
							</div>
						</div>
						<div>
							<h3 class:list={['font-display text-2xl md:text-3xl font-bold mb-3', c.dark ? 'text-white' : 'text-neutral-900']}>{c.title}</h3>
							<p class:list={['text-sm md:text-base leading-relaxed max-w-md', c.dark ? 'text-white/70' : 'text-neutral-500']}>{c.desc}</p>
						</div>
					</div>
				</div>
			))}
			<!-- Extra space at bottom so last card stays visible -->
			<div style="height: 30vh"></div>
		</div>
	</div>
</section>

<style>
	.stacked-card {
		min-height: 220px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		transition: box-shadow 0.3s ease;
	}
	/* Mobile: reduce card height and sticky offset */
	@media (max-width: 768px) {
		.stacked-card {
			min-height: 200px;
		}
	}
</style>
