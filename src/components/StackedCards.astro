---
const cards = [
	{
		num: '01',
		title: 'Assessment',
		desc: 'Comprehensive evaluation of your condition, mobility, and pain points to build an accurate clinical picture.',
		color: 'bg-olive-50',
		accent: 'text-olive-600',
	},
	{
		num: '02',
		title: 'Treatment Plan',
		desc: 'Personalized, evidence-based protocol combining manual therapy, electrotherapy, and therapeutic exercises.',
		color: 'bg-stone-100',
		accent: 'text-neutral-700',
	},
	{
		num: '03',
		title: 'Home Sessions',
		desc: 'Regular treatment sessions at your home with full equipment. No travel stress, no clinic queues.',
		color: 'bg-neutral-900',
		accent: 'text-olive-400',
		dark: true,
	},
	{
		num: '04',
		title: 'Recovery',
		desc: 'Progressive milestones, exercises you can do between sessions, and ongoing support until you are fully recovered.',
		color: 'bg-olive-600',
		accent: 'text-olive-100',
		dark: true,
	},
];
---

<section class="py-24 lg:py-32 bg-white" id="process">
	<div class="max-w-5xl mx-auto px-6">
		<div class="text-center mb-16" data-animate>
			<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium mb-4">Process</p>
			<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight">
				How it works.
			</h2>
		</div>

		<!-- Cards with direction-aware scroll animation -->
		<div class="process-stack relative max-w-2xl mx-auto">
			{cards.map((c, i) => (
				<div
					class:list={[
						'process-card rounded-2xl p-8 md:p-12 shadow-lg mb-6 last:mb-0',
						c.color
					]}
					data-process-card={String(i)}
					style={`--card-index: ${i};`}
				>
					<div class="flex items-start justify-between mb-6">
						<span class:list={['font-mono text-sm font-semibold', c.accent]}>{c.num}</span>
						<div class:list={['w-10 h-10 rounded-full border opacity-30 flex items-center justify-center', c.dark ? 'border-white' : 'border-neutral-400']}>
							<span class:list={['text-base', c.dark ? 'text-white' : 'text-neutral-500']}>→</span>
						</div>
					</div>
					<div>
						<h3 class:list={['font-display text-2xl md:text-3xl font-bold mb-3', c.dark ? 'text-white' : 'text-neutral-900']}>{c.title}</h3>
						<p class:list={['text-sm md:text-base leading-relaxed max-w-md', c.dark ? 'text-white/70' : 'text-neutral-500']}>{c.desc}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.process-card {
		min-height: 200px;
		opacity: 0;
		transform: translateY(60px);
		transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
					transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
					box-shadow 0.4s ease;
	}

	/* Visible state — scrolling down, cards enter from below */
	.process-card.card-in {
		opacity: 1;
		transform: translateY(0);
	}

	/* Exit state — scrolling up, cards leave upward */
	.process-card.card-out-up {
		opacity: 0;
		transform: translateY(-40px);
	}

	.process-card.card-in:hover {
		transform: translateY(-4px);
		box-shadow: 0 25px 60px rgba(0,0,0,0.1);
	}

	/* Desktop: sticky stacking effect */
	@media (min-width: 768px) {
		.process-card.card-in {
			position: sticky;
			top: calc(80px + var(--card-index) * 30px);
			margin-bottom: 0;
		}
		.process-card.card-in + .process-card.card-in {
			margin-top: 30px;
		}
		.process-stack {
			padding-bottom: 120px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.process-card {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>

<script>
	let lastScrollY = window.scrollY;
	let scrollDir: 'down' | 'up' = 'down';

	window.addEventListener('scroll', () => {
		scrollDir = window.scrollY > lastScrollY ? 'down' : 'up';
		lastScrollY = window.scrollY;
	}, { passive: true });

	const processCards = document.querySelectorAll('[data-process-card]');
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!reducedMotion && processCards.length > 0) {
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				const card = entry.target as HTMLElement;
				const idx = parseInt(card.getAttribute('data-process-card') || '0');
				const delay = idx * 120;

				if (entry.isIntersecting) {
					// Entering viewport — animate in
					card.classList.remove('card-out-up');
					setTimeout(() => {
						card.classList.add('card-in');
					}, delay);
				} else {
					// Leaving viewport
					if (scrollDir === 'up') {
						// Scrolling up — card exits upward
						card.classList.remove('card-in');
						card.classList.add('card-out-up');
						// Reset to default (below) state after transition for re-entry
						setTimeout(() => {
							card.classList.remove('card-out-up');
						}, 700);
					} else {
						// Scrolling down past — just keep visible or reset
						// (this happens when card is above viewport)
					}
				}
			});
		}, { threshold: 0.15, rootMargin: '0px 0px -30px 0px' });

		processCards.forEach(card => observer.observe(card));
	}
</script>
