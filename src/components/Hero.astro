---
---

<section id="home" class="relative min-h-screen flex items-center pt-20">
	<div class="max-w-6xl mx-auto px-6 py-20 grid lg:grid-cols-5 gap-16 items-center">
		<!-- Left: Content (3 cols) -->
		<div class="lg:col-span-3 space-y-8" data-animate="fade-up">
			<div class="space-y-2">
				<p class="text-sm tracking-[0.2em] uppercase text-teal-600 font-medium">Physiotherapist  /  Lucknow</p>
				<h1 class="text-5xl md:text-6xl lg:text-7xl font-medium leading-[1.1] text-gray-900 tracking-tight">
					Healing hands,<br/>
					<span class="text-teal-600">at your</span> doorstep.
				</h1>
			</div>

			<p class="text-lg text-gray-400 leading-relaxed max-w-md">
				Personalized physiotherapy care delivered where you're most comfortable.
				Evidence-based treatment for lasting recovery.
			</p>

			<div class="flex flex-wrap gap-4 pt-2">
				<a href="#booking"
					class="group inline-flex items-center gap-3 bg-gray-900 text-white pl-7 pr-5 py-4 rounded-full hover:bg-gray-800 transition-all duration-300">
					<span class="text-sm font-medium">Book a Session</span>
					<span class="w-8 h-8 bg-white/10 rounded-full flex items-center justify-center group-hover:bg-white/20 transition-all">
						<svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					</span>
				</a>
				<a href="https://wa.me/91XXXXXXXXXX?text=Hi%2C%20I%20would%20like%20to%20book%20a%20physiotherapy%20session."
					target="_blank" rel="noopener"
					class="inline-flex items-center gap-2 border border-gray-200 text-gray-600 px-6 py-4 rounded-full hover:border-gray-300 hover:text-gray-900 transition-all duration-300 text-sm font-medium">
					<svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					WhatsApp
				</a>
			</div>

			<!-- Minimal stats -->
			<div class="flex gap-10 pt-6 border-t border-gray-100">
				<div>
					<p class="text-2xl font-semibold text-gray-900">BPT</p>
					<p class="text-xs text-gray-400 mt-1">Certified</p>
				</div>
				<div>
					<p class="text-2xl font-semibold text-gray-900">6 mo</p>
					<p class="text-xs text-gray-400 mt-1">Clinical Training</p>
				</div>
				<div>
					<p class="text-2xl font-semibold text-gray-900">Home</p>
					<p class="text-xs text-gray-400 mt-1">Visits Available</p>
				</div>
			</div>
		</div>

		<!-- Right: Photo (2 cols) -->
		<div class="lg:col-span-2" data-animate="fade-up" data-delay="200">
			<div class="relative">
				<div class="aspect-[3/4] rounded-2xl overflow-hidden">
					<img src="/images/muskan.jpg" alt="Dr. Muskan - Physiotherapist"
						class="w-full h-full object-cover" />
				</div>
				<!-- Subtle accent line -->
				<div class="absolute -bottom-3 -right-3 w-full h-full rounded-2xl border border-teal-200/40 -z-10"></div>
			</div>
		</div>
	</div>
</section>
