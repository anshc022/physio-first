---
---

<section id="home" class="relative min-h-screen flex items-center pt-20 overflow-hidden">
	<!-- Parallax Background -->
	<div class="parallax-bg absolute inset-0 opacity-[0.06]"
		style="background-image: radial-gradient(circle at 1px 1px, #0d9488 1px, transparent 0); background-size: 32px 32px;"
		data-speed="0.3">
	</div>

	<!-- Floating shapes with parallax -->
	<div class="parallax-element absolute top-32 right-10 w-72 h-72 bg-teal-200/20 rounded-full blur-3xl" data-speed="0.5"></div>
	<div class="parallax-element absolute bottom-20 left-10 w-60 h-60 bg-teal-100/20 rounded-full blur-3xl" data-speed="0.2"></div>
	<div class="parallax-element absolute top-1/2 left-1/3 w-40 h-40 bg-teal-300/10 rounded-full blur-2xl" data-speed="0.7"></div>

	<!-- Floating particles -->
	<div class="particles absolute inset-0 pointer-events-none overflow-hidden">
		<div class="particle w-2 h-2 bg-teal-400/20 rounded-full absolute" style="top:20%;left:15%;animation:float 6s ease-in-out infinite"></div>
		<div class="particle w-3 h-3 bg-teal-300/15 rounded-full absolute" style="top:60%;left:80%;animation:float 8s ease-in-out infinite 1s"></div>
		<div class="particle w-1.5 h-1.5 bg-teal-500/20 rounded-full absolute" style="top:40%;left:50%;animation:float 7s ease-in-out infinite 2s"></div>
		<div class="particle w-2.5 h-2.5 bg-teal-200/25 rounded-full absolute" style="top:80%;left:30%;animation:float 9s ease-in-out infinite 0.5s"></div>
	</div>

	<div class="max-w-7xl mx-auto px-6 py-16 grid lg:grid-cols-2 gap-12 items-center">
		<!-- Left Content -->
		<div class="z-10">
			<div class="reveal reveal-left inline-flex items-center gap-2 bg-teal-50 text-teal-700 px-4 py-2 rounded-full text-sm font-medium mb-6 backdrop-blur-sm">
				<span class="w-2 h-2 bg-teal-500 rounded-full animate-pulse"></span>
				Home Visit Physiotherapy Available
			</div>

			<h1 class="reveal reveal-left text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight text-gray-900 mb-6" style="animation-delay:0.1s">
				Empowering Your
				<span class="text-teal-600"> Recovery</span>,
				<br/>One Step at a Time
			</h1>

			<p class="reveal reveal-left text-lg text-gray-500 leading-relaxed max-w-lg mb-8" style="animation-delay:0.2s">
				Expert physiotherapy care delivered to your doorstep. Personalized treatment plans
				for orthopedic, neurological, and sports injuries.
			</p>

			<div class="reveal reveal-left flex flex-col sm:flex-row gap-4 mb-12" style="animation-delay:0.3s">
				<a href="#booking"
					class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-teal-600 to-teal-700 text-white px-8 py-4 rounded-full font-semibold hover:from-teal-700 hover:to-teal-800 hover:shadow-xl hover:shadow-teal-200/50 transition-all duration-300 text-base transform hover:-translate-y-0.5">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
					Book Appointment
				</a>
				<a href="#services"
					class="inline-flex items-center justify-center gap-2 border-2 border-gray-200 text-gray-700 px-8 py-4 rounded-full font-semibold hover:border-teal-300 hover:text-teal-700 hover:bg-teal-50/50 transition-all duration-300 text-base">
					View Services
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
				</a>
			</div>

			<!-- Trust badges -->
			<div class="reveal reveal-up flex flex-wrap gap-6" style="animation-delay:0.4s">
				{[
					{ icon: '🎓', label: 'BPT Certified' },
					{ icon: '🏥', label: '6-Month Clinical Training' },
					{ icon: '🏠', label: 'Home Visits' },
				].map((badge, i) => (
					<div class="flex items-center gap-2 text-sm text-gray-500 bg-white/60 backdrop-blur-sm px-3 py-2 rounded-xl border border-gray-100/50">
						<span class="text-lg">{badge.icon}</span>
						<span>{badge.label}</span>
					</div>
				))}
			</div>
		</div>

		<!-- Right Image - Real Photo -->
		<div class="relative z-10 reveal reveal-right">
			<div class="relative">
				<div class="aspect-[4/5] rounded-3xl overflow-hidden border border-teal-100 shadow-2xl shadow-teal-100/50">
					<img src="/muskan-doctor.jpg" alt="Dr. Muskan Kumari - Physiotherapist" class="w-full h-full object-cover object-top" />
				</div>

				<!-- Floating card -->
				<div class="absolute -bottom-4 -left-4 bg-white/90 backdrop-blur-xl rounded-2xl shadow-xl p-4 flex items-center gap-3 border border-gray-100 transform hover:scale-105 transition-transform duration-300">
					<div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
						<span class="text-2xl">⭐</span>
					</div>
					<div>
						<p class="font-heading font-bold text-gray-900">4.9 Rating</p>
						<p class="text-xs text-gray-400">Patient satisfaction</p>
					</div>
				</div>

				<!-- Experience badge -->
				<div class="absolute -top-3 -right-3 bg-gradient-to-br from-teal-600 to-teal-700 text-white rounded-2xl shadow-xl px-5 py-3 text-center transform hover:scale-105 transition-transform duration-300">
					<p class="font-heading font-bold text-xl">BPT</p>
					<p class="text-[10px] uppercase tracking-wider text-teal-100">Certified</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	@keyframes float {
		0%, 100% { transform: translateY(0px) rotate(0deg); }
		33% { transform: translateY(-10px) rotate(1deg); }
		66% { transform: translateY(5px) rotate(-1deg); }
	}
</style>
