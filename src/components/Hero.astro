---
---

<section id="home" class="min-h-screen relative overflow-hidden">
	<!-- Hero background image with parallax -->
	<div class="absolute inset-0 parallax-hero overflow-hidden">
		<img src="/images/hero-physio.jpg" alt="Physiotherapy treatment" class="w-full h-full object-cover scale-110 parallax-img" />
		<div class="absolute inset-0 bg-gradient-to-r from-[#1a1917]/95 via-[#1a1917]/75 to-[#1a1917]/45"></div>
	</div>

	<div class="relative z-10 min-h-screen flex flex-col justify-center max-w-5xl mx-auto px-6 py-32">
		<p class="text-olive-300 text-xs tracking-[0.3em] uppercase font-medium mb-6" data-animate data-delay="400">
			Physiotherapy · Lucknow
		</p>

		<h1 class="font-display text-4xl sm:text-5xl md:text-[3.5rem] lg:text-[4.5rem] font-extrabold text-white leading-[1.05] tracking-tightest mb-6 max-w-2xl" data-split>
			Recovery that comes to you.
		</h1>

		<p class="text-neutral-300 text-base sm:text-lg max-w-md leading-relaxed mb-10" data-animate data-delay="600">
			Professional physiotherapy at your doorstep. Evidence-based treatment plans for pain, mobility, and rehabilitation — across Lucknow.
		</p>

		<div class="flex gap-3 mb-20 sm:flex-row flex-col" data-animate data-delay="700">
			<a href="#booking" class="magnetic-btn bg-white text-neutral-900 px-7 py-4 rounded-lg text-sm font-semibold hover:bg-olive-50 transition-colors text-center inline-block">
				Book a Home Visit
			</a>
			<a href="https://wa.me/919142405611?text=Hi%2C%20I%27d%20like%20to%20book%20a%20physio%20session."
				target="_blank" rel="noopener"
				class="magnetic-btn border border-white/20 text-white px-7 py-4 rounded-lg text-sm font-medium hover:bg-white/10 transition-colors flex items-center justify-center gap-2.5">
				<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
				WhatsApp
			</a>
		</div>

		<!-- Stats with counter animation -->
		<div class="grid grid-cols-3 gap-8 max-w-md" data-animate data-delay="900">
			<div>
				<p class="text-2xl font-display font-bold text-white">BPT</p>
				<p class="text-[11px] text-neutral-400 tracking-wider uppercase mt-1">Certified</p>
			</div>
			<div>
				<p class="text-2xl font-display font-bold text-white"><span data-count="500" data-suffix="+">0</span></p>
				<p class="text-[11px] text-neutral-400 tracking-wider uppercase mt-1">Clinical Hours</p>
			</div>
			<div>
				<p class="text-2xl font-display font-bold text-white">Home</p>
				<p class="text-[11px] text-neutral-400 tracking-wider uppercase mt-1">Visits Available</p>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10" data-animate data-delay="1200">
		<div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center pt-2">
			<div class="w-1 h-2.5 bg-white/50 rounded-full animate-bounce"></div>
		</div>
	</div>
</section>
