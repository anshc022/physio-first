---
---

<!-- Bento Grid: visual feature cards with mixed sizes -->
<section class="py-24 lg:py-32 bg-stone-50">
	<div class="max-w-5xl mx-auto px-6">
		<div class="text-center mb-14" data-animate>
			<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium mb-4">Why Choose Us</p>
			<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight">
				Care designed around you.
			</h2>
		</div>

		<!-- Bento grid -->
		<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 auto-rows-[140px] md:auto-rows-[160px]">
			<!-- Card 1: Home visits — large, spans 2 cols + 2 rows -->
			<div class="col-span-2 row-span-2 rounded-2xl overflow-hidden relative group cursor-default" data-animate data-delay="0">
				<img src="/images/sports-rehab.jpg" alt="Home physiotherapy" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
				<div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent"></div>
				<div class="relative z-10 h-full flex flex-col justify-end p-6">
					<p class="text-[10px] tracking-widest uppercase text-olive-300 mb-1.5">Home Visits</p>
					<h3 class="font-display text-xl font-bold text-white">Treatment at your doorstep</h3>
					<p class="text-neutral-300 text-sm mt-1.5 max-w-xs">Full equipment, full expertise — no need to travel.</p>
				</div>
			</div>

			<!-- Card 2: BPT credential -->
			<div class="col-span-1 row-span-1 bg-neutral-900 rounded-2xl p-5 flex flex-col justify-between" data-animate data-delay="80">
				<div class="w-9 h-9 bg-olive-500/20 rounded-lg flex items-center justify-center">
					<svg class="w-5 h-5 text-olive-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342"/></svg>
				</div>
				<div>
					<p class="font-display text-2xl font-bold text-white">BPT</p>
					<p class="text-xs text-neutral-400">Integral University</p>
				</div>
			</div>

			<!-- Card 3: Clinical hours -->
			<div class="col-span-1 row-span-1 bg-olive-600 rounded-2xl p-5 flex flex-col justify-between" data-animate data-delay="160">
				<p class="font-display text-3xl font-bold text-white">500+</p>
				<div>
					<p class="text-sm text-olive-100">Clinical Hours</p>
					<p class="text-[11px] text-olive-200/60">Across all specializations</p>
				</div>
			</div>

			<!-- Card 4: Specializations -->
			<div class="col-span-1 row-span-1 bg-white border border-neutral-100 rounded-2xl p-5 flex flex-col justify-between" data-animate data-delay="240">
				<p class="text-[10px] tracking-wider uppercase text-neutral-300 font-medium">Specializations</p>
				<div class="space-y-1">
					{['Ortho','Neuro','Cardio','Geriatric'].map(s => (
						<p class="text-xs text-neutral-600">{s}</p>
					))}
				</div>
			</div>

			<!-- Card 5: Treatment image -->
			<div class="col-span-1 row-span-1 rounded-2xl overflow-hidden relative group" data-animate data-delay="320">
				<img src="/images/back-therapy.jpg" alt="Treatment" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
				<div class="absolute inset-0 bg-neutral-900/30"></div>
			</div>

			<!-- Card 6: Mon-Sat schedule -->
			<div class="col-span-2 row-span-1 bg-stone-100 border border-neutral-100 rounded-2xl p-5 flex items-center justify-between" data-animate data-delay="400">
				<div>
					<p class="font-display text-lg font-bold text-neutral-900">Mon – Sat</p>
					<p class="text-sm text-neutral-400">8 AM – 8 PM · Sunday by appointment</p>
				</div>
				<div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center">
					<svg class="w-6 h-6 text-olive-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
				</div>
			</div>
		</div>
	</div>
</section>
