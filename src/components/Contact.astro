---
---

<section id="contact" class="py-28 bg-white">
	<div class="max-w-6xl mx-auto px-6">
		<div class="grid md:grid-cols-2 gap-16 items-start">
			<div data-animate="fade-up">
				<p class="text-sm tracking-[0.2em] uppercase text-teal-600 font-medium mb-4">Contact</p>
				<h2 class="text-4xl md:text-5xl font-medium text-gray-900 tracking-tight mb-6">
					Let's talk.
				</h2>
				<p class="text-gray-400 leading-relaxed mb-12">
					Have questions about treatment or want to discuss your needs before booking?
					Reach out anytime.
				</p>

				<div class="space-y-6">
					<a href="tel:+91XXXXXXXXXX" class="flex items-center gap-4 group">
						<div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center group-hover:bg-teal-50 transition-colors">
							<svg class="w-5 h-5 text-gray-400 group-hover:text-teal-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
							</svg>
						</div>
						<div>
							<p class="text-sm font-medium text-gray-900">Phone</p>
							<p class="text-sm text-gray-400">+91 XXXXX XXXXX</p>
						</div>
					</a>

					<a href="mailto:muskan@example.com" class="flex items-center gap-4 group">
						<div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center group-hover:bg-teal-50 transition-colors">
							<svg class="w-5 h-5 text-gray-400 group-hover:text-teal-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
							</svg>
						</div>
						<div>
							<p class="text-sm font-medium text-gray-900">Email</p>
							<p class="text-sm text-gray-400">muskan@example.com</p>
						</div>
					</a>

					<div class="flex items-center gap-4">
						<div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center">
							<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
							</svg>
						</div>
						<div>
							<p class="text-sm font-medium text-gray-900">Location</p>
							<p class="text-sm text-gray-400">Lucknow, Uttar Pradesh</p>
						</div>
					</div>
				</div>
			</div>

			<div data-animate="fade-up" data-delay="150">
				<div class="bg-stone-50 rounded-2xl p-10 border border-gray-100">
					<h3 class="text-lg font-medium text-gray-900 mb-2">Home visits available</h3>
					<p class="text-sm text-gray-400 mb-8">
						I bring all the necessary equipment to your home. Available for morning
						and evening slots across Lucknow.
					</p>

					<div class="space-y-4">
						<div class="flex justify-between text-sm">
							<span class="text-gray-400">Availability</span>
							<span class="text-gray-900">Mon - Sat</span>
						</div>
						<div class="flex justify-between text-sm border-t border-gray-100 pt-4">
							<span class="text-gray-400">Morning slots</span>
							<span class="text-gray-900">8:00 AM - 12:00 PM</span>
						</div>
						<div class="flex justify-between text-sm border-t border-gray-100 pt-4">
							<span class="text-gray-400">Evening slots</span>
							<span class="text-gray-900">4:00 PM - 8:00 PM</span>
						</div>
						<div class="flex justify-between text-sm border-t border-gray-100 pt-4">
							<span class="text-gray-400">Coverage</span>
							<span class="text-gray-900">All Lucknow</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
