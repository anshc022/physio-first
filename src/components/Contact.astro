<section id="contact" class="py-28 bg-white">
	<div class="max-w-5xl mx-auto px-6">
		<div class="grid md:grid-cols-12 gap-12 md:gap-16">
			<div class="md:col-span-3" data-animate>
				<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium sticky top-24">Contact</p>
			</div>

			<div class="md:col-span-9" data-animate data-delay="100">
				<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight leading-tight mb-12">
					Get in touch.
				</h2>

				<div class="grid sm:grid-cols-3 gap-8 mb-12">
					<a href="tel:+919142405611" class="group">
						<p class="text-[11px] tracking-[0.2em] uppercase text-neutral-300 font-medium mb-2">Phone</p>
						<p class="text-sm text-neutral-900 group-hover:text-olive-600 transition-colors">+91 91424 05611</p>
					</a>
					<a href="mailto:muskankumari@email.com" class="group">
						<p class="text-[11px] tracking-[0.2em] uppercase text-neutral-300 font-medium mb-2">Email</p>
						<p class="text-sm text-neutral-900 group-hover:text-olive-600 transition-colors">muskankumari@email.com</p>
					</a>
					<div>
						<p class="text-[11px] tracking-[0.2em] uppercase text-neutral-300 font-medium mb-2">Location</p>
						<p class="text-sm text-neutral-900">Lucknow, Uttar Pradesh</p>
					</div>
				</div>

				<div class="border-t border-neutral-100 pt-8">
					<div class="grid sm:grid-cols-3 gap-8 text-sm">
						<div>
							<p class="text-neutral-400 mb-1">Mon – Sat</p>
							<p class="text-neutral-800">8:00 AM – 8:00 PM</p>
						</div>
						<div>
							<p class="text-neutral-400 mb-1">Sunday</p>
							<p class="text-neutral-800">By appointment</p>
						</div>
						<div>
							<p class="text-neutral-400 mb-1">Coverage</p>
							<p class="text-neutral-800">All Lucknow (home visits)</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
