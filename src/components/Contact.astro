---
---

<section id="contact" class="py-24 bg-white">
	<div class="max-w-7xl mx-auto px-6">
		<div class="text-center mb-16">
			<p class="text-sm uppercase tracking-widest text-teal-600 font-semibold mb-3">Get in Touch</p>
			<h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">Contact</h2>
		</div>

		<div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
			<a href="tel:+91XXXXXXXXXX" class="group bg-stone-50 rounded-2xl p-8 border border-gray-100 hover:border-teal-200 hover:shadow-lg transition-all duration-300 text-center">
				<div class="w-14 h-14 bg-teal-50 group-hover:bg-teal-100 rounded-2xl flex items-center justify-center mx-auto mb-4 transition-colors">
					<svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
				</div>
				<p class="font-heading font-bold text-gray-900 mb-1">Phone</p>
				<p class="text-sm text-gray-400">+91 XXXXX XXXXX</p>
			</a>

			<a href="mailto:muskan@example.com" class="group bg-stone-50 rounded-2xl p-8 border border-gray-100 hover:border-teal-200 hover:shadow-lg transition-all duration-300 text-center">
				<div class="w-14 h-14 bg-teal-50 group-hover:bg-teal-100 rounded-2xl flex items-center justify-center mx-auto mb-4 transition-colors">
					<svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
					</svg>
				</div>
				<p class="font-heading font-bold text-gray-900 mb-1">Email</p>
				<p class="text-sm text-gray-400">muskan@example.com</p>
			</a>

			<div class="group bg-stone-50 rounded-2xl p-8 border border-gray-100 hover:border-teal-200 hover:shadow-lg transition-all duration-300 text-center">
				<div class="w-14 h-14 bg-teal-50 group-hover:bg-teal-100 rounded-2xl flex items-center justify-center mx-auto mb-4 transition-colors">
					<svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
					</svg>
				</div>
				<p class="font-heading font-bold text-gray-900 mb-1">Location</p>
				<p class="text-sm text-gray-400">Lucknow, Uttar Pradesh</p>
			</div>
		</div>

		<!-- Home service badge -->
		<div class="text-center mt-12">
			<div class="inline-flex items-center gap-3 bg-teal-50 border border-teal-100 rounded-full px-6 py-3">
				<span class="text-lg">🏠</span>
				<span class="text-sm font-medium text-teal-700">Home Service Available Across Lucknow</span>
			</div>
		</div>
	</div>
</section>
