---
const specializations = [
	{ icon: '🦴', title: 'Orthopedic Rehab', desc: 'Recovery from fractures, joint replacements, and musculoskeletal conditions.' },
	{ icon: '🧠', title: 'Neurological Rehab', desc: 'Stroke recovery, nerve injuries, and neurological movement disorders.' },
	{ icon: '❤️', title: 'Cardiopulmonary Rehab', desc: 'Breathing exercises, cardiac recovery, and endurance training.' },
	{ icon: '👴', title: 'Geriatric Care', desc: 'Mobility improvement, balance training, and fall prevention for seniors.' },
	{ icon: '⚽', title: 'Sports Injury', desc: 'ACL recovery, muscle tears, and return-to-sport rehabilitation.' },
];
---

<section id="about" class="py-24 bg-white">
	<div class="max-w-7xl mx-auto px-6">
		<div class="grid lg:grid-cols-2 gap-16 items-start">
			<!-- Left: Photo + Info -->
			<div>
				<div class="aspect-[3/4] rounded-3xl overflow-hidden bg-gradient-to-br from-teal-50 to-stone-100 mb-8 relative">
					<div class="absolute inset-0 flex items-center justify-center">
						<div class="text-center">
							<span class="text-6xl mb-4 block">👩‍⚕️</span>
							<span class="text-teal-400 text-sm uppercase tracking-widest">About Photo</span>
						</div>
					</div>
				</div>

				<!-- Education card -->
				<div class="bg-stone-50 rounded-2xl p-6 border border-gray-100">
					<h4 class="font-heading font-bold text-gray-900 mb-3">Education</h4>
					<div class="space-y-3">
						<div class="flex gap-3">
							<div class="w-10 h-10 bg-teal-50 rounded-lg flex items-center justify-center flex-shrink-0">
								<span>🎓</span>
							</div>
							<div>
								<p class="font-medium text-sm text-gray-900">Bachelor of Physiotherapy (BPT)</p>
								<p class="text-xs text-gray-400">Integral University, Lucknow | 2026</p>
							</div>
						</div>
						<div class="flex gap-3">
							<div class="w-10 h-10 bg-teal-50 rounded-lg flex items-center justify-center flex-shrink-0">
								<span>🏥</span>
							</div>
							<div>
								<p class="font-medium text-sm text-gray-900">6-Month Rotatory Internship</p>
								<p class="text-xs text-gray-400">Ortho, Neuro, Cardiopulmonary, Geriatrics</p>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Right: Bio + Specializations -->
			<div>
				<p class="text-sm uppercase tracking-widest text-teal-600 font-semibold mb-3">About Me</p>
				<h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6">
					Dr. Muskan
				</h2>
				<p class="text-lg text-gray-500 leading-relaxed mb-4">
					A dedicated physiotherapist committed to helping patients regain their mobility,
					strength, and independence. With hands-on clinical experience across multiple specialties,
					I deliver personalized, evidence-based treatment plans.
				</p>
				<p class="text-lg text-gray-500 leading-relaxed mb-10">
					I believe in bringing care to where patients are most comfortable — their homes.
					Whether you're recovering from surgery, managing chronic pain, or rehabilitating
					from a sports injury, I'm here to guide your recovery journey.
				</p>

				<!-- Specializations -->
				<h3 class="font-heading font-bold text-gray-900 text-xl mb-6">Specializations</h3>
				<div class="grid gap-4">
					{specializations.map(spec => (
						<div class="flex gap-4 items-start p-4 rounded-xl bg-stone-50 hover:bg-teal-50 border border-transparent hover:border-teal-100 transition-all duration-300 group cursor-default">
							<div class="w-11 h-11 bg-teal-100 group-hover:bg-teal-200 rounded-xl flex items-center justify-center flex-shrink-0 transition-colors">
								<span class="text-xl">{spec.icon}</span>
							</div>
							<div>
								<p class="font-heading font-bold text-gray-900 text-sm">{spec.title}</p>
								<p class="text-sm text-gray-400 mt-0.5">{spec.desc}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</div>
</section>
