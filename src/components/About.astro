---
---

<section id="about" class="py-28 bg-white">
	<div class="max-w-6xl mx-auto px-6">
		<div class="grid lg:grid-cols-2 gap-20 items-start">
			<!-- Left: Text-only (no duplicate photo) -->
			<div data-animate="fade-up">
				<p class="text-sm tracking-[0.2em] uppercase text-teal-600 font-medium mb-6">About</p>
				<h2 class="text-4xl md:text-5xl font-medium text-gray-900 tracking-tight mb-8">
					Dedicated to<br/>your recovery.
				</h2>

				<div class="space-y-4 text-gray-400 leading-relaxed mb-12">
					<p>
						I'm a physiotherapist based in Lucknow with a Bachelor of Physiotherapy from
						Integral University. My 6-month clinical rotatory internship gave me hands-on
						experience across orthopedic, neurological, cardiopulmonary, and geriatric care.
					</p>
					<p>
						I bring therapy to your home because recovery shouldn't wait. Every treatment plan
						is built around your unique needs, your pace, your goals.
					</p>
				</div>

				<!-- Specializations -->
				<div class="space-y-4">
					<p class="text-xs tracking-[0.15em] uppercase text-gray-300 font-medium">Specializations</p>
					<div class="grid grid-cols-2 gap-3">
						{[
							'Orthopedic Rehab',
							'Neurological Rehab',
							'Cardiopulmonary',
							'Geriatric Care',
							'Sports Injury',
							'Home Physiotherapy',
						].map(spec => (
							<div class="flex items-center gap-2 text-sm text-gray-600">
								<span class="w-1 h-1 bg-teal-500 rounded-full"></span>
								{spec}
							</div>
						))}
					</div>
				</div>
			</div>

			<!-- Right: Education + Stats (no photo) -->
			<div data-animate="fade-up" data-delay="150">
				<!-- Big number stats -->
				<div class="grid grid-cols-2 gap-6 mb-12">
					<div class="bg-stone-50 rounded-2xl p-8">
						<p class="text-4xl font-light text-gray-900 mb-2">6</p>
						<p class="text-xs text-gray-400 uppercase tracking-wider">Months Clinical Training</p>
					</div>
					<div class="bg-stone-50 rounded-2xl p-8">
						<p class="text-4xl font-light text-teal-600 mb-2">BPT</p>
						<p class="text-xs text-gray-400 uppercase tracking-wider">Certified Graduate</p>
					</div>
					<div class="bg-stone-50 rounded-2xl p-8">
						<p class="text-4xl font-light text-gray-900 mb-2">4</p>
						<p class="text-xs text-gray-400 uppercase tracking-wider">Specializations</p>
					</div>
					<div class="bg-stone-50 rounded-2xl p-8">
						<p class="text-4xl font-light text-teal-600 mb-2">24h</p>
						<p class="text-xs text-gray-400 uppercase tracking-wider">Response Time</p>
					</div>
				</div>

				<!-- Education timeline -->
				<div class="space-y-6">
					<p class="text-xs tracking-[0.15em] uppercase text-gray-300 font-medium">Education</p>
					<div class="border-l-2 border-gray-100 pl-6 space-y-8">
						<div class="relative">
							<div class="absolute -left-[31px] top-1 w-3 h-3 bg-teal-500 rounded-full"></div>
							<p class="text-sm font-medium text-gray-900">Bachelor of Physiotherapy (BPT)</p>
							<p class="text-xs text-gray-400 mt-1">Integral University, Lucknow  ·  2026</p>
						</div>
						<div class="relative">
							<div class="absolute -left-[31px] top-1 w-3 h-3 bg-gray-200 rounded-full"></div>
							<p class="text-sm font-medium text-gray-900">Clinical Rotatory Internship</p>
							<p class="text-xs text-gray-400 mt-1">6 months  ·  Ortho, Neuro, Cardio, Geriatrics</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
