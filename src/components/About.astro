---
---

<section id="about" class="py-28">
	<div class="max-w-5xl mx-auto px-6">
		<div class="grid md:grid-cols-12 gap-12 md:gap-16">
			<!-- Label -->
			<div class="md:col-span-3" data-animate>
				<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium sticky top-24">About</p>
			</div>

			<!-- Content -->
			<div class="md:col-span-9" data-animate data-delay="100">
				<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight leading-tight mb-8">
					I believe recovery should happen where you feel safest — your home.
				</h2>

				<div class="space-y-5 text-neutral-500 leading-[1.75] mb-12 max-w-xl">
					<p>
						With a Bachelor of Physiotherapy from Integral University and six months
						of clinical training across orthopedics, neurology, cardiopulmonary, and
						geriatric care, I bring hospital-grade expertise to your doorstep.
					</p>
					<p>
						Every treatment plan starts with listening. Your condition, your goals,
						your pace. No cookie-cutter exercises, no rushed sessions — just focused,
						one-on-one care tailored to you.
					</p>
				</div>

				<!-- Skills as a quiet horizontal list -->
				<div class="border-t border-neutral-200 pt-8">
					<p class="text-[11px] tracking-[0.2em] uppercase text-neutral-300 font-medium mb-5">Clinical Training</p>
					<div class="grid grid-cols-2 md:grid-cols-3 gap-4">
						{[
							'Patient Assessment & Diagnosis',
							'Manual Therapy',
							'Electrotherapy (TENS, IFT, US)',
							'Therapeutic Exercise',
							'Gait & Posture Analysis',
							'Rehab Program Design',
						].map(s => (
							<span class="text-[13px] text-neutral-600">{s}</span>
						))}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
