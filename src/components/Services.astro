---
const services = [
	{
		title: 'Home Visit Physiotherapy',
		desc: 'Professional treatment at your doorstep — equipment, expertise, and personalized care delivered to your home.',
		img: '/images/home-visit.png',
		tag: 'Most Requested',
		large: true,
	},
	{
		title: 'Orthopaedic Rehab',
		desc: 'Post-surgery rehabilitation, joint mobilization, fracture recovery, and musculoskeletal conditioning.',
		img: '/images/ortho-rehab.png',
		large: true,
	},
	{
		title: 'Back & Neck Pain',
		desc: 'Manual therapy, spinal mobilization, and corrective exercises for chronic and acute pain.',
		img: '/images/neck-therapy.jpg',
	},
	{
		title: 'Sports Injury Recovery',
		desc: 'Return-to-play rehabilitation with progressive strengthening and sport-specific reconditioning.',
		img: '/images/sports-rehab.jpg',
	},
	{
		title: 'Neurological Rehab',
		desc: 'Stroke recovery, nerve palsy management, and motor re-education for neurological conditions.',
		img: '/images/neuro-rehab.png',
	},
	{
		title: 'Geriatric Mobility',
		desc: 'Fall prevention, balance training, and functional exercises to maintain senior independence.',
		img: '/images/geriatric-care.png',
	},
];
---

<section id="services" class="py-24 lg:py-32 bg-white">
	<div class="max-w-5xl mx-auto px-6">
		<div class="text-center mb-16" data-animate>
			<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium mb-4">Services</p>
			<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight" data-split>
				What I treat.
			</h2>
			<p class="text-neutral-400 mt-4 max-w-md mx-auto text-[15px] leading-relaxed">
				Available for clinic and home visits across Lucknow. Each plan is personalized.
			</p>
		</div>

		<!-- Top row: 2 large image cards -->
		<div class="grid md:grid-cols-2 gap-4 mb-4">
			{services.filter(s => s.large).map((s, i) => (
				<a href="#booking" class="group block rounded-2xl overflow-hidden bg-neutral-900 relative aspect-[4/3] cursor-pointer card-lift cursor-grow" data-animate-scale data-delay={String(i * 100)}>
					<img src={s.img} alt={s.title} class="absolute inset-0 w-full h-full object-cover opacity-50 img-zoom" loading="lazy" />
					<div class="absolute inset-0 bg-gradient-to-t from-neutral-900/90 via-neutral-900/30 to-transparent"></div>
					<div class="relative z-10 h-full flex flex-col justify-end p-7">
						{s.tag && (
							<span class="inline-block self-start text-[9px] tracking-widest uppercase text-olive-300 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded-full mb-3 border border-white/10">{s.tag}</span>
						)}
						<h3 class="font-display text-xl font-bold text-white mb-2 group-hover:translate-x-1 transition-transform duration-500">{s.title}</h3>
						<p class="text-neutral-300 text-sm leading-relaxed max-w-sm opacity-0 group-hover:opacity-100 transition-opacity duration-500">{s.desc}</p>
					</div>
				</a>
			))}
		</div>

		<!-- Middle row: 4 cards in 2x2 grid -->
		<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
			{services.filter(s => !s.large).map((s, i) => (
				<a href="#booking" class="group block rounded-2xl overflow-hidden border border-neutral-100 bg-white card-lift cursor-grow" data-animate data-delay={String((i + 2) * 80)}>
					<div class="aspect-[4/3] overflow-hidden relative">
						<img src={s.img} alt={s.title} class="w-full h-full object-cover img-zoom" loading="lazy" />
						<div class="absolute inset-0 bg-neutral-900/0 group-hover:bg-neutral-900/10 transition-colors duration-500"></div>
					</div>
					<div class="p-4 sm:p-5">
						<h3 class="font-display text-sm sm:text-base font-semibold text-neutral-900 group-hover:text-olive-600 transition-colors mb-1.5 leading-tight">{s.title}</h3>
						<p class="text-neutral-400 text-xs sm:text-[13px] leading-relaxed line-clamp-2">{s.desc}</p>
					</div>
				</a>
			))}
		</div>
	</div>
</section>
