---
const services = [
	{
		title: 'Home Visit Physiotherapy',
		desc: 'Professional treatment at your doorstep — equipment, expertise, and personalized care delivered to your home.',
		tag: 'Most Requested',
	},
	{
		title: 'Post-Surgery Rehabilitation',
		desc: 'Structured recovery after joint replacement, ACL repair, spinal surgery, and fracture fixation.',
	},
	{
		title: 'Back & Neck Pain',
		desc: 'Manual therapy, mobilization, and corrective exercises for chronic and acute musculoskeletal pain.',
	},
	{
		title: 'Sports Injury Recovery',
		desc: 'Return-to-play rehabilitation with progressive strengthening and sport-specific reconditioning.',
	},
	{
		title: 'Geriatric Mobility',
		desc: 'Fall prevention, balance training, and functional exercises to maintain senior independence.',
	},
	{
		title: 'Neurological Rehab',
		desc: 'Stroke recovery, nerve palsy management, and motor re-education for neurological conditions.',
	},
];
---

<section id="services" class="py-28 bg-white">
	<div class="max-w-5xl mx-auto px-6">
		<div class="grid md:grid-cols-12 gap-12 md:gap-16 mb-16">
			<div class="md:col-span-3" data-animate>
				<p class="text-[11px] tracking-[0.25em] uppercase text-olive-500 font-medium sticky top-24">Services</p>
			</div>
			<div class="md:col-span-9" data-animate data-delay="100">
				<h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight leading-tight">
					What I treat.
				</h2>
			</div>
		</div>

		<div class="max-w-5xl mx-auto">
			{services.map((s, i) => (
				<a href="#booking"
					class="group grid md:grid-cols-12 gap-4 md:gap-8 py-7 border-b border-neutral-100 items-baseline hover:border-neutral-300 transition-colors cursor-pointer"
					data-animate data-delay={String(i * 60)}>
					<div class="md:col-span-1 text-[11px] text-neutral-300 font-mono">
						{String(i + 1).padStart(2, '0')}
					</div>
					<div class="md:col-span-4">
						<h3 class="text-lg font-display font-semibold text-neutral-900 group-hover:text-olive-600 transition-colors">
							{s.title}
						</h3>
						{s.tag && (
							<span class="inline-block mt-1.5 text-[10px] tracking-wider uppercase text-olive-600 bg-olive-50 px-2 py-0.5 rounded">{s.tag}</span>
						)}
					</div>
					<div class="md:col-span-6">
						<p class="text-sm text-neutral-400 leading-relaxed">{s.desc}</p>
					</div>
					<div class="md:col-span-1 hidden md:flex justify-end">
						<svg class="w-4 h-4 text-neutral-200 group-hover:text-olive-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					</div>
				</a>
			))}
		</div>
	</div>
</section>
